#!/usr/bin/env bash

set -euo pipefail

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly RESET='\033[0m'
readonly BOLD='\033[1m'

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly DOTFILES_DIR

# Helpers

print_header() {
    echo -e "\n${BOLD}${BLUE}==>${RESET} ${BOLD}$1${RESET}"
}

print_success() {
    echo -e "${GREEN}✓${RESET} $1"
}

print_error() {
    echo -e "${RED}✗${RESET} $1" >&2
}

print_warning() {
    echo -e "${YELLOW}⚠${RESET} $1"
}

print_info() {
    echo -e "${CYAN}ℹ${RESET} $1"
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Homebrew prefixes for the running platform, in preference order.
# Apple Silicon prefers /opt/homebrew (native); Intel macs prefer /usr/local;
# Linux uses linuxbrew. Other platforms get an empty list.
brew_candidates() {
    case "$(uname -s)" in
        Darwin)
            if [[ "$(uname -m)" == "arm64" ]]; then
                printf '%s\n' /opt/homebrew/bin/brew /usr/local/bin/brew
            else
                printf '%s\n' /usr/local/bin/brew /opt/homebrew/bin/brew
            fi
            ;;
        Linux)
            printf '%s\n' /home/linuxbrew/.linuxbrew/bin/brew
            ;;
    esac
}

# Trust gate for `eval $(brew shellenv)`: only run binaries owned by root or
# the current user. GNU stat (Linux) first, BSD stat (macOS) as fallback —
# reversing the order would cause GNU stat -f to dump filesystem info to
# stdout and contaminate the captured owner value.
brew_owner_is_safe() {
    local bin="$1" owner
    owner="$(stat -c %u "$bin" 2>/dev/null || stat -f %u "$bin" 2>/dev/null)"
    [[ -n "$owner" ]] || return 1
    [[ "$owner" == "0" || "$owner" == "$(id -u)" ]]
}

# Accept a brew already on PATH only if it resolves into a known prefix —
# guards against a shadowing binary or shell function getting eval'd.
brew_on_path_is_trusted() {
    local resolved
    resolved="$(command -v brew 2>/dev/null)" || return 1
    if command -v realpath >/dev/null 2>&1; then
        resolved="$(realpath "$resolved" 2>/dev/null || echo "$resolved")"
    fi
    case "$resolved" in
        /opt/homebrew/*|/home/linuxbrew/.linuxbrew/*|/usr/local/Homebrew/*|/usr/local/Cellar/*|/usr/local/bin/brew)
            return 0
            ;;
    esac
    return 1
}

# Source brew shellenv so brew (and everything it installed) is on PATH.
# Returns 0 only if a usable, trusted brew is on PATH afterwards.
ensure_brew_on_path() {
    if command_exists brew && brew_on_path_is_trusted; then
        return 0
    fi
    local candidate
    while IFS= read -r candidate; do
        [[ -x "$candidate" ]] || continue
        brew_owner_is_safe "$candidate" || continue
        eval "$("$candidate" shellenv)"
        command_exists brew && return 0
        return 1
    done < <(brew_candidates)
    return 1
}

# Backup conflicting files then stow

stow_dotfiles() {
    local home_dir="${DOTFILES_DIR}/home"
    local backup_dir="${DOTFILES_DIR}/backups/$(date +%Y%m%d_%H%M%S)"
    local has_conflicts=false

    # Find files that would conflict with stow
    while IFS= read -r -d '' file; do
        local relative="${file#"${home_dir}"/}"
        local target="${HOME}/${relative}"

        # Skip if the target is reached via a stow-folded parent symlink
        # (the leaf isn't a symlink, but it resolves into the dotfiles repo).
        if [[ -e "$target" && ! -L "$target" ]]; then
            local resolved
            resolved="$(realpath "$target" 2>/dev/null || readlink -f "$target" 2>/dev/null || echo "$target")"
            if [[ "$resolved" == "${home_dir}"/* ]]; then
                continue
            fi
            has_conflicts=true
            mkdir -p "$(dirname "${backup_dir}/${relative}")"
            cp -p "$target" "${backup_dir}/${relative}"
            print_warning "Conflict detected: $target exists. Back it up manually."
        fi
    done < <(find "$home_dir" -type f -print0)

    if [[ "$has_conflicts" == true ]]; then
        print_info "Backed up conflicting files to ${backup_dir}"
    fi

    if stow -R -d "${DOTFILES_DIR}" -t "${HOME}" home; then
        print_success "Dotfiles stowed successfully"
    else
        print_error "Failed to stow dotfiles"
        return 1
    fi
}

# Commands

cmd_init() {
    print_header "Initializing dotfiles"

    # 1. Homebrew
    if command_exists brew; then
        print_success "Homebrew is already installed"
    else
        print_info "Installing Homebrew..."
        if NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
            if ! ensure_brew_on_path; then
                print_error "Homebrew installed but brew binary not found in known prefixes"
                return 1
            fi
            print_success "Homebrew installed"
        else
            print_error "Failed to install Homebrew"
            return 1
        fi
    fi

    # 2. Packages
    print_info "Installing packages from Brewfile..."
    if brew bundle --file="${DOTFILES_DIR}/Brewfile"; then
        print_success "All packages installed"
    else
        print_warning "Some packages failed to install"
    fi

    # Unlink Homebrew's node so nvm.fish controls the Node version
    if brew ls --versions node >/dev/null 2>&1; then
        brew unlink node >/dev/null 2>&1
        print_success "Unlinked Homebrew node (managed by nvm instead)"
    fi

    # 3. Stow
    print_info "Stowing dotfiles..."
    stow_dotfiles

    # 4. Fish as default shell
    local fish_path
    fish_path="$(command -v fish)"

    if ! grep -q "$fish_path" /etc/shells 2>/dev/null; then
        print_info "Adding Fish to /etc/shells (requires sudo)..."
        echo "$fish_path" | sudo tee -a /etc/shells >/dev/null
    fi

    if [[ "$SHELL" != "$fish_path" ]]; then
        print_info "Setting Fish as default shell..."
        if chsh -s "$fish_path"; then
            print_success "Default shell changed to Fish"
        else
            print_error "Failed to change default shell"
        fi
    else
        print_success "Fish is already the default shell"
    fi

    # 5. Fisher & plugins (Fish plugin manager)
    print_info "Installing Fisher & updating Fish plugins..."
    fish -c '
    # Install Fisher if not installed
    if not functions -q fisher
        curl -sL https://git.io/fisher | source
    end
    
    # Update plugins
    fisher update
    '
    print_success "Fisher & Fish plugins updated"

    # 6. Clean up universal variables that conflict with conf.d settings
    fish -c 'set --erase --universal nvm_default_version 2>/dev/null'
    fish -c 'set --erase --universal PATH 2>/dev/null'
    print_success "Cleaned up universal Fish variables"

    # 7. Remove stale system-level Node binaries (e.g. from old pkg installers)
    for bin in node npm npx; do
        if [ -f "/usr/local/bin/$bin" ]; then
            sudo rm "/usr/local/bin/$bin"
        fi
    done
    print_success "Removed stale system Node binaries (if any)"

    print_header "Done! Open a new terminal to see your new prompt."
}

cmd_stow() {
    print_header "Stowing dotfiles"
    stow_dotfiles
}

cmd_update() {
    print_header "Updating dotfiles"

    print_info "Pulling latest changes..."
    if git -C "$DOTFILES_DIR" pull; then
        print_success "Repository updated"
    else
        print_error "Failed to pull"
        return 1
    fi

    stow_dotfiles
}

cmd_doctor() {
    print_header "Running diagnostics"

    ensure_brew_on_path || true

    local issues=0

    # Homebrew
    if command_exists brew; then
        print_success "Homebrew installed"
    else
        local found=""
        while IFS= read -r candidate; do
            if [[ -x "$candidate" ]]; then
                found="$candidate"
                break
            fi
        done < <(brew_candidates)
        if [[ -n "$found" ]]; then
            print_error "Homebrew at $found exists but cannot bootstrap PATH"
            print_info "  Verify ownership (you or root) and that 'brew shellenv' produces valid output"
        else
            print_error "Homebrew not installed"
        fi
        ((++issues))
    fi

    # Check Brewfile packages
    if command_exists brew && [[ -f "${DOTFILES_DIR}/Brewfile" ]]; then
        if brew bundle check --file="${DOTFILES_DIR}/Brewfile" >/dev/null 2>&1; then
            print_success "All Brewfile packages installed"
        else
            print_warning "Some Brewfile packages are missing"
            brew bundle check --file="${DOTFILES_DIR}/Brewfile" 2>&1 | while IFS= read -r line; do
                print_info "  $line"
            done
        fi
    fi

    # Stow
    if command_exists stow; then
        print_success "GNU Stow installed"
    else
        print_error "GNU Stow not installed"
        ((++issues))
    fi

    # Fish
    if command_exists fish; then
        print_success "Fish shell installed"
        if [[ "$SHELL" == "$(command -v fish)" ]]; then
            print_success "Fish is default shell"
        else
            print_warning "Fish is not default shell (current: $SHELL)"
        fi
    else
        print_error "Fish shell not installed"
        ((++issues))
    fi

    # Starship
    if command_exists starship; then
        print_success "Starship prompt installed"
    else
        print_error "Starship not installed"
        ((++issues))
    fi

    # Ghostty
    if [[ "$(uname -s)" == "Darwin" ]]; then
        if [[ -d "/Applications/Ghostty.app" ]]; then
            print_success "Ghostty installed"
        else
            print_warning "Ghostty not found in /Applications"
        fi
    elif command_exists ghostty; then
        print_success "Ghostty installed"
    else
        print_warning "Ghostty not found on PATH"
    fi

    # Key symlinks
    local expected_links=(
        ".config/fish/config.fish"
        ".config/ghostty/config"
        ".config/git/config"
        ".config/starship.toml"
    )

    local broken=0
    for link in "${expected_links[@]}"; do
        local target="${HOME}/${link}"
        if [[ -L "$target" ]]; then
            if [[ -e "$target" ]]; then
                print_success "Symlink OK: ~/${link}"
            else
                print_error "Broken symlink: ~/${link}"
                ((++broken))
            fi
        elif [[ -e "$target" ]] && [[ "$(realpath "$target")" == "${DOTFILES_DIR}"/* ]]; then
            # File exists and resolves into dotfiles (via symlinked parent dir)
            print_success "Managed by dotfiles: ~/${link}"
        else
            print_warning "Not managed by dotfiles: ~/${link}"
            ((++broken))
        fi
    done

    # Git config location
    if [[ -f "${HOME}/.gitconfig" ]]; then
        print_warning "~/.gitconfig exists (may override ~/.config/git/config)"
    fi

    echo ""
    if [[ $issues -eq 0 && $broken -eq 0 ]]; then
        print_success "All checks passed!"
    else
        print_warning "Found $issues critical issues, $broken symlink issues"
    fi
}

cmd_help() {
    echo -e "${BOLD}Usage:${RESET} run <command>"
    echo ""
    echo -e "${BOLD}Commands:${RESET}"
    echo "    init      Full setup: Homebrew, packages, stow, Fish shell"
    echo "    stow      Backup conflicts and re-stow dotfiles"
    echo "    update    Pull latest changes and re-stow"
    echo "    doctor    Run diagnostics"
    echo "    help      Show this message"
}

# Main

case "${1:-help}" in
    init)   cmd_init ;;
    stow)   cmd_stow ;;
    update) cmd_update ;;
    doctor) cmd_doctor ;;
    help)   cmd_help ;;
    *)
        print_error "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
